{
  "name": "rock-paper-scissors",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run dev:server & bun run dev:client",
    "dev:server": "bun run --filter server dev",
    "dev:client": "bun run --filter client dev",
    "build": "bun run --filter '*' build",
    "typecheck": "tsc -b"
  }
}
